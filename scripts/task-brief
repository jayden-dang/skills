#!/usr/bin/env bash
# task-brief <tasks.md> <N> — extract Task N plus the Global Constraints section
# into .skills/task-N-brief.md and print the path. The implementer subagent reads
# this file instead of the whole plan.
set -euo pipefail

PLAN="${1:?usage: task-brief <tasks.md> <task-number>}"
N="${2:?usage: task-brief <tasks.md> <task-number>}"
OUT_DIR=".skills"
OUT="$OUT_DIR/task-$N-brief.md"

[ -f "$PLAN" ] || { echo "task-brief: no such file: $PLAN" >&2; exit 1; }
mkdir -p "$OUT_DIR"

# Task headings are `## Task N:` or `### Task N:` depending on the plan. A task
# body ends at the next heading of any level, so a trailing section such as
# `## Coverage check` never bleeds into the last task's brief.
awk -v n="$N" '
  /^## Global Constraints/ { gc = 1; next }
  gc && /^##+ / { gc = 0 }
  gc { constraints = constraints $0 "\n"; next }
  $0 ~ ("^##+ Task " n ":") { intask = 1; task = task $0 "\n"; next }
  intask && /^##+ / { intask = 0 }
  intask { task = task $0 "\n" }
  END {
    if (task == "") { print "task-brief: Task " n " not found" > "/dev/stderr"; exit 1 }
    print "# Task Brief\n"
    print "This brief is your requirements. Read it fully before starting.\n"
    if (constraints != "") print "## Global Constraints (apply to every task)\n\n" constraints
    print task
  }
' "$PLAN" > "$OUT"

echo "$OUT"

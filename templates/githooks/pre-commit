#!/bin/sh
# Pre-commit verify gate — vendored into a repo by `setup-repo` (opt-in).
# Runs this repo's FAST checks so a broken commit never lands. Keep it quick;
# slow suites belong in pre-push. Bypass once with `git commit --no-verify`.
#
# Installed at <repo>/.githooks/pre-commit and activated with:
#   git config core.hooksPath .githooks
set -e

# setup-repo replaces the lines below with this repo's fast verify commands from
# docs/agents/project.md — typically format-staged, lint, and typecheck.
pnpm exec tsc -b
pnpm lint

#!/bin/sh
# Pre-push verify gate — vendored into a repo by `setup-repo` (opt-in).
# Runs the fuller suite before code is shared: the test suites plus the
# traceability lint. Bypass once with `git push --no-verify`.
#
# Installed at <repo>/.githooks/pre-push and activated with:
#   git config core.hooksPath .githooks
set -e

# setup-repo replaces the lines below with this repo's full verify commands from
# docs/agents/project.md, plus the two linters: the trace lint (fails on untraced
# requirements) and the graph lint (fails on a stale committed GRAPH.md). The
# linters are Python 3.9+ stdlib scripts, so only `python3` is required — no node.
pnpm test
python3 scripts/check_trace.py
python3 scripts/check_graph.py --verify
